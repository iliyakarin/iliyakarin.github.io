---
import { Image } from "astro:assets";
import iliya2Image from "../assets/iliya2.jpg";
import PricingCard from "./PricingCard.astro";
import Icon from "./Icon.astro";
---

<section id="pricing" class="bg-slate-800 py-16">
    <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
        <div class="mx-auto max-w-screen-md text-center mb-8 lg:mb-12">
            <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-white">
                Engagement Packages
            </h2>
            <p class="mb-5 font-light text-gray-400 sm:text-xl">
                Transparent pricing for fixed-scope audits and strategic
                roadmaps. Custom engagements available.
            </p>
        </div>
        <div
            class="space-y-8 lg:grid lg:grid-cols-3 sm:gap-6 xl:gap-10 lg:space-y-0"
        >
            <!-- Pricing Card 1 -->
            <PricingCard
                title="Security Audit"
                description="Prevent data loss and PII exposure. Essential for passing heavy client DDQs."
                price="$5k+"
                features={[
                    "Infrastructure Security Scan",
                    "SOC2 Gap Analysis",
                    "Timeline: ~1 Week",
                ]}
            />
            <!-- Pricing Card 2 -->
            <PricingCard
                title="Infra Automation"
                description="Save countless developer hours, prevent incidents, and focus on code."
                price="$10k+"
                features={[
                    "Terraform/Ansible Audit",
                    "CI/CD Optimization Plan",
                    "Timeline: 1-2 Weeks",
                ]}
                isPopular={true}
            />
            <!-- Pricing Card 3 -->
            <PricingCard
                title="AI Architecture"
                description="On-premise AI audit and strategic roadmap."
                price="$8k+"
                features={[
                    "Hardware/GPU Sizing",
                    "Privacy & Security Audit",
                    "Timeline: 2 Weeks",
                ]}
            />
        </div>

        <!-- Hourly Consult -->
        <div
            class="mt-12 p-8 bg-slate-700 rounded-lg flex flex-col md:flex-row items-center justify-between gap-8"
        >
            <div class="text-left flex-1">
                <h3 class="text-2xl font-bold text-white mb-2">
                    Hourly Consultation
                </h3>
                <p class="text-gray-300 mb-4">
                    Troubleshooting, Architectural Review, Interviewing for your
                    team.
                </p>
                <div class="text-3xl font-bold text-blue-400">
                    $200 - $450 / hour
                </div>
                <p class="text-sm text-gray-400 mt-2">
                    Rate depends on task complexity and engagement duration.
                </p>
            </div>
            <div class="flex-shrink-0">
                <Image
                    src={iliya2Image}
                    alt="Iliya Karin"
                    class="w-70 h-70 rounded-lg object-cover border-4 border-slate-600 shadow-xl"
                />
            </div>
        </div>
    </div>
</section>

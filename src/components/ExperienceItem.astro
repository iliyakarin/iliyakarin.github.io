---
import { Image } from "astro:assets";

interface Props {
  logo: any;
  altText: string;
  title: string;
  date: string;
  company: string;
  bullets: string[];
  tags: string[];
}

const { logo, altText, title, date, company, bullets, tags } = Astro.props;
---

<div class="ml-6 md:ml-12">
    <span
        class="absolute flex items-center justify-center w-20 h-20 bg-white rounded-full -left-10 ring-8 ring-slate-900 overflow-hidden"
    >
        <Image
            src={logo}
            alt={altText}
            class="w-16 h-16 object-contain"
        />
    </span>
    <div
        class="p-6 bg-slate-800 rounded-lg border border-gray-700 shadow-md"
    >
        <div
            class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4"
        >
            <h3 class="text-2xl font-bold text-white">
                {title}
            </h3>
            <span
                class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-blue-900 dark:text-blue-300 mt-2 sm:mt-0"
                >{date}</span
            >
        </div>
        <p class="text-lg font-semibold text-gray-300 mb-2">
            {company}
        </p>
        <ul class="list-disc list-inside text-gray-400 space-y-2 mb-4">
            {bullets.map((bullet) => (
                <li set:html={bullet}></li>
            ))}
        </ul>
        <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
                <span class="text-xs font-semibold px-2.5 py-0.5 rounded bg-blue-900 text-blue-300">
                    {tag}
                </span>
            ))}
        </div>
    </div>
</div>

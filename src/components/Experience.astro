---
import { Image } from "astro:assets";
import ExperienceItem from "./ExperienceItem.astro";
import inventLogo from "../assets/invent-logo.webp";
import vtbLogo from "../assets/vtb-bank-logo.png";
import nokiaLogo from "../assets/nokia-logo.png";
import gazpromLogo from "../assets/gazprom-logo.svg";
---

<section id="experience" class="bg-slate-900 py-16">
    <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
        <div class="mx-auto max-w-screen-sm text-center lg:mb-16 mb-8">
            <h2
                class="mb-4 text-3xl lg:text-4xl tracking-tight font-extrabold text-white"
            >
                Experience
            </h2>
            <p class="font-light text-gray-400 sm:text-xl">
                A proven track record of securing enterprise environments and
                leading high-performance teams.
            </p>
        </div>
        <div class="relative border-l border-gray-700 ml-3 md:ml-6 space-y-12">
            <!-- Invent -->
            <ExperienceItem
                logo={inventLogo}
                altText="Invent Logo"
                title="Director of DevOps"
                date="Oct 2022 – Present"
                company="Invent (Austin, TX)"
                bullets={[
                    "Achieved <strong>64%+ annual cloud savings</strong> through strategic rightsizing and architecture redesign.",
                    "Reduced environment provisioning time from 3–4 days to <strong>~1–2 hours</strong> via GitOps & IaC.",
                    "Designed a <strong>SOC2-compliant DevSecOps ecosystem</strong> (SAST/DAST, secrets management, policy-as-code).",
                    "Scaled a high-performing team of 14 DevOps/SRE engineers."
                ]}
                tags={["Kubernetes", "OpenTelemetry", "SOC2"]}
            />

            <!-- Innotech (VTB Bank) -->
            <ExperienceItem
                logo={vtbLogo}
                altText="VTB Bank Logo"
                title="Senior DevOps Manager"
                date="Aug 2020 – Oct 2022"
                company="Innotech / VTB Bank"
                bullets={[
                    "Led DevOps for a division of <strong>550+ engineers</strong> at a bank with <strong>$460B+ annual turnover</strong>.",
                    "Reduced deployment time from hours to minutes using automated Teamcity with Kotlin DSL auto generated pipelines.",
                    "Implemented production-grade <strong>OpenShift</strong> and microservices infrastructure.",
                    "Spearheaded observability transformation with Prometheus, Grafana, and ELK."
                ]}
                tags={["OpenShift", "FinTech", "Terraform"]}
            />

            <!-- Nokia -->
            <ExperienceItem
                logo={nokiaLogo}
                altText="Nokia Logo"
                title="Principal SRE"
                date="Mar 2019 – Aug 2020"
                company="Nokia"
                bullets={[
                    "Led deployment of the <strong>Nokia IMPACT IoT platform</strong> for large enterprise/telecom clients.",
                    "Designed high-availability infrastructure for geo-distributed environments.",
                    "Optimized platform scalability for <strong>millions of connected devices</strong>.",
                    "Automated lifecycle management using Ansible and Python."
                ]}
                tags={["IoT", "High Availability", "Python"]}
            />

            <!-- Gazprom -->
            <ExperienceItem
                logo={gazpromLogo}
                altText="Gazprom Logo"
                title="Lead DevOps Engineer"
                date="Jun 2015 – Mar 2019"
                company="Gazprom"
                bullets={[
                    "<strong>Re-architected entire infrastructure</strong> and implemented a 3-2-1 backup strategy for critical data clusters.",
                    "World's first integration of <strong>PureStorage NVMe</strong> via 10Gb iSCSI with VMware vSphere.",
                    "Deployed <strong>Thin Client</strong> terminal solutions to create highly secure, cost-effective workspaces.",
                    "Implemented complete workspace control and audit solutions for <strong>government compliance</strong> in the energy sector."
                ]}
                tags={["PureStorage NVMe", "VMware", "Governance"]}
            />

            <!-- Prior Experience -->
            <div class="ml-6 md:ml-12">
                <span
                    class="absolute flex items-center justify-center w-6 h-6 bg-slate-800 rounded-full -left-3 ring-8 ring-slate-900 border border-gray-600"
                >
                    <svg
                        class="w-2.5 h-2.5 text-gray-400"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"
                        ></path>
                    </svg>
                </span>
                <div
                    class="p-4 bg-slate-800/50 rounded-lg border border-gray-700/50"
                >
                    <div
                        class="flex flex-col sm:flex-row justify-between sm:items-center"
                    >
                        <span class="text-lg font-medium text-gray-300"
                            >Previous relevant Enterprise IT experience</span
                        >
                        <span class="text-sm text-gray-500 mt-1 sm:mt-0"
                            >Jan 2012 – May 2015</span
                        >
                    </div>
                </div>
            </div>

            <!-- Education -->
            <div class="ml-6 md:ml-12">
                <span
                    class="absolute flex items-center justify-center w-6 h-6 bg-purple-900 rounded-full -left-3 ring-8 ring-slate-900"
                >
                    <svg
                        class="w-3 h-3 text-purple-300"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            d="M10 0a10 10 0 1 0 10 10A10.011 10.011 0 0 0 10 0Zm0 5a3 3 0 1 1 0 6 3 3 0 0 1 0-6Zm0 13a8.949 8.949 0 0 1-4.951-1.488A3.987 3.987 0 0 1 9 13h2a3.987 3.987 0 0 1 3.951 3.512A8.949 8.949 0 0 1 10 18Z"
                        ></path>
                    </svg>
                </span>
                <div
                    class="p-6 bg-slate-800 rounded-lg border border-gray-700 shadow-md"
                >
                    <div
                        class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-2"
                    >
                        <h3 class="text-xl font-bold text-white">
                            Master's Degree in Computer Science
                        </h3>
                        <span
                            class="bg-purple-100 text-purple-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-purple-900 dark:text-purple-300 mt-2 sm:mt-0"
                            >2005 – 2011</span
                        >
                    </div>
                    <p class="text-gray-400">
                        MATI (Russian State Technological University)
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

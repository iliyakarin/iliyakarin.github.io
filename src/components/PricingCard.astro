---
import Icon from "./Icon.astro";

const { title, description, price, features, isPopular = false } = Astro.props;
---

<div
    class={`flex flex-col p-6 mx-auto max-w-lg text-center rounded-lg border shadow border-gray-600 bg-slate-900 text-white h-full justify-between ${
        isPopular ? "relative overflow-hidden" : ""
    }`}
>
    {
        isPopular && (
            <div class="absolute top-0 right-0 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-bl-lg">
                POPULAR
            </div>
        )
    }
    <div>
        <h3 class="mb-4 text-2xl font-semibold">{title}</h3>
        <p class="font-light text-gray-400 sm:text-lg">
            {description}
        </p>
        <div class="flex justify-center items-baseline my-8">
            <span class="mr-2 text-5xl font-extrabold">{price}</span>
        </div>
        <!-- List -->
        <ul role="list" class="mb-8 space-y-4 text-left">
            {
                features.map((feature) => (
                    <li class="flex items-center space-x-3">
                        <Icon
                            name="checkmark"
                            class="flex-shrink-0 w-5 h-5 text-green-400"
                        />
                        <span>{feature}</span>
                    </li>
                ))
            }
        </ul>
    </div>
    <a
        href="#contact"
        class="text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:ring-blue-200 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:focus:ring-blue-900 mt-auto"
        >Get Started</a
    >
</div>

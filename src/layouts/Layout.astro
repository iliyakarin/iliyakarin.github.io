---
import "../styles/global.css";
import IconSprite from "../components/IconSprite.astro";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta
			http-equiv="Content-Security-Policy"
			content="default-src 'self'; script-src 'self' 'unsafe-inline' https://assets.calendly.com; style-src 'self' 'unsafe-inline'; frame-src https://calendly.com; img-src 'self' data:; connect-src 'self'; form-action https://formspree.io; object-src 'none'; base-uri 'self';"
		/>
		<title>Iliya Karin | DevSecOps Consultant | EB-1A Expert</title>
		<meta
			name="description"
			content="Senior DevSecOps Consultant specialized in Cloud Security, CI/CD Hardening, and Compliance."
		/>
	</head>
	<body class="bg-slate-900 text-white font-sans antialiased">
		<IconSprite />
		<slot />
	</body>
</html>
